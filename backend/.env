# Environment variables for Weather Assistant Backend

# Server Configuration
PORT=3001
NODE_ENV=development

# Aviation API Keys (add your actual keys here)
# NOAA_API_KEY=your_noaa_api_key_here
# FAA_API_KEY=your_faa_api_key_here
# AVWX_API_KEY=your_avwx_api_key_here

# CORS settings
CORS_ORIGIN=http://localhost:5173

# Logging
LOG_LEVEL=info

# API Rate Limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# Cache settings
CACHE_TTL_SECONDS=300